{
  "extends": "./tsconfig.json",
  "compilerOptions": {
    "outDir": ".tmp-tests",
    "module": "nodenext",
    "target": "ES2021",
    "skipLibCheck": true,
    "declaration": false,
    "moduleResolution": "nodenext",
    "noEmit": false
  },
  "include": [
    "src/domain/playerRecovery.ts",
    "src/domain/textProcessing.ts",
    "src/domain/generationRun.ts",
    "src/domain/sourceValidation.ts",
    "src/services/telemetry.ts",
    "src/stores/settingsParsing.ts",
    "src/stores/pipelineRunStore.ts"
  ]
}
